# Server port (default: 3001)
PORT=3001

# Environment (default: development)
NODE_ENV=development

# Encryption key for secrets at rest (GitHub tokens, API keys).
# 32 bytes as 64 hex chars or base64. If unset, a random key is generated on
# first run and stored at <data-dir>/.encryption-key (mode 0600).
# VIBE_KANBAN_ENCRYPTION_KEY=

# Headless task runs execute in an isolated git worktree on a vk/<task>-<run>
# branch (success -> changes committed to the branch + worktree removed; failure
# -> worktree + branch deleted). Default ON for git repos. Set to 0 to run the
# agent directly in the project working tree instead.
# VK_TASK_WORKTREES=1

# Headless-run concurrency cap (default 3) and per-run timeout (default 15min).
# VK_HEADLESS_CLAUDE_CONCURRENCY=3
# VK_HEADLESS_CLAUDE_TIMEOUT_MS=900000

# Max attempts per auto-spawned task run on failure (default 2 = one retry,
# clamped 1..5). Each attempt is a fresh run/worktree and its own task_ai_runs row.
# VK_TASK_MAX_ATTEMPTS=2
